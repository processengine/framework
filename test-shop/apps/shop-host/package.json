    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "migrate": "node dist/migrate.js"
  },
  "dependencies": {
    "@test-shop/contracts": "0.1.0",
    "@test-shop/host-adapter": "0.1.0",
    "fastify": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "engines": { "node": ">=22.0.0" }
}

