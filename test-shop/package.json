{
  "name": "processengine-test-shop",
  "version": "0.1.0",
  "private": true,
  "description": "External three-service acceptance contour for @processengine/conductor",
  "type": "module",
  "workspaces": [
    "packages/contracts",
    "packages/host-adapter",
    "packages/service-kit",
    "apps/shop-host",
    "apps/shop-warehouse",
    "apps/shop-payment"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run build && npm run typecheck --workspaces --if-present",
    "test": "npm run build && vitest run",
    "check": "npm run build && npm run typecheck --workspaces --if-present && vitest run",
    "images:build": "node scripts/images.mjs build",
    "compose:doctor": "node scripts/compose.mjs doctor",
    "compose:deploy": "node scripts/compose.mjs deploy",
    "compose:deploy:local": "node scripts/compose.mjs deploy local",
    "compose:deploy:registry": "node scripts/compose.mjs deploy registry",
    "compose:up": "node scripts/compose.mjs up",
    "compose:test": "node scripts/compose.mjs test",
    "compose:down": "node scripts/compose.mjs down",
    "helm:lint": "helm lint deploy/helm/test-shop -f deploy/helm/test-shop/values.docker-desktop.yaml",
    "helm:render": "helm template test-shop deploy/helm/test-shop -f deploy/helm/test-shop/values.docker-desktop.yaml",
    "k8s:doctor": "node scripts/k8s.mjs doctor",
    "k8s:deploy": "node scripts/k8s.mjs deploy",
    "k8s:deploy:local": "node scripts/k8s.mjs deploy local",
    "k8s:deploy:registry": "node scripts/k8s.mjs deploy registry",
    "k8s:test": "node scripts/k8s.mjs test",
    "k8s:resilience": "node scripts/k8s.mjs resilience",
    "k8s:collect": "node scripts/k8s.mjs collect",
    "k8s:down": "node scripts/k8s.mjs down"
  },
  "dependencies": {
    "@processengine/conductor": "0.1.0",
    "@processengine/storage-postgres": "0.1.0",
    "@processengine/transport-kafka": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
