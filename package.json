{
  "name": "processengine-local-contour",
  "version": "0.1.0",
  "private": true,
  "description": "Framework and long-running Docker Desktop Kubernetes acceptance contour",
  "scripts": {
    "bootstrap": "node scripts/contour.mjs bootstrap",
    "check": "node scripts/contour.mjs check:registry",
    "check:local": "node scripts/contour.mjs check:local",
    "check:registry": "node scripts/contour.mjs check:registry",
    "pack": "node scripts/contour.mjs pack",
    "review:bundle": "node scripts/review-bundle.mjs",
    "compose:deploy": "npm --prefix test-shop run compose:deploy",
    "compose:deploy:local": "npm --prefix test-shop run compose:deploy:local",
    "compose:deploy:registry": "npm --prefix test-shop run compose:deploy:registry",
    "k8s:doctor": "npm --prefix test-shop run k8s:doctor",
    "k8s:deploy": "npm --prefix test-shop run k8s:deploy",
    "k8s:deploy:local": "npm --prefix test-shop run k8s:deploy:local",
    "k8s:deploy:registry": "npm --prefix test-shop run k8s:deploy:registry",
    "k8s:test": "npm --prefix test-shop run k8s:test",
    "k8s:resilience": "npm --prefix test-shop run k8s:resilience --",
    "k8s:collect": "npm --prefix test-shop run k8s:collect",
    "k8s:down": "npm --prefix test-shop run k8s:down"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
